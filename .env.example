# ---- OKX API credentials ----
# Create on OKX (use a Demo/paper key while OKX_USE_DEMO=true).
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
# true = OKX demo/paper trading, false = real money
OKX_USE_DEMO=true

# ---- Trading config ----
TRADING_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT
QUOTE_CURRENCY=USDT

# ---- Risk management ----
ACCOUNT_BASE=10000
BASE_RISK_PERCENT=0.01
MAX_SINGLE_TRADE_USD=150
MAX_PORTFOLIO_VALUE=500
MAX_OPEN_POSITIONS=3
MAX_DRAWDOWN_STOP=-10.0
DAILY_LOSS_LIMIT=-3.0

# ---- Strategy ----
PROFIT_TARGET_PCT=0.03
STOP_LOSS_PCT=0.02
ATR_STOP_MULTIPLIER=2.0
MAX_HOLD_HOURS=8.0
DUST_VALUE_USD=1.50

# ---- Loop / server ----
LOOP_INTERVAL_SEC=60
STATUS_PORT=8080
BOT_NAME=apex_oracle_bot

# ---- Optional: persistence (leave default for SQLite) ----
# DATABASE_URL=sqlite:////app/data/trades.db

# ---- Optional: Telegram alerts ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Optional: Base44 dashboard ----
DASHBOARD_API_KEY=
BASE44_API_URL=https://api.base44.com/api/apps/YOUR_APP_ID/entities
